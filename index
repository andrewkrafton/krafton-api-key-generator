<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🔑 AI API Key Name Generator</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans KR', sans-serif;
    background: #1a1a1a;
    color: #e0e0e0;
    min-height: 100vh;
    padding: 32px 16px 60px;
  }

  /* TOP BADGE */
  .top-badge {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .top-badge span {
    background: #3b5bdb;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 5px 16px;
    border-radius: 4px;
  }

  /* HEADER */
  .header {
    text-align: center;
    margin-bottom: 36px;
  }
  .header h1 {
    font-size: 32px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 8px;
  }
  .header p {
    font-size: 14px;
    color: #888;
  }

  /* CARD */
  .card {
    background: #242424;
    border: 1px solid #333;
    border-radius: 12px;
    padding: 28px 32px;
    max-width: 860px;
    margin: 0 auto 24px;
  }

  .card-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    margin-bottom: 20px;
    color: #ccc;
  }
  .card-title .icon { margin-right: 6px; }

  /* GRID */
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 28px;
  }
  @media (max-width: 600px) {
    .grid-2 { grid-template-columns: 1fr; }
    .card { padding: 20px 18px; }
  }

  /* FIELD */
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #aaa;
    text-transform: uppercase;
  }
  .field label .req { color: #e03131; margin-left: 3px; }

  .field input, .field input[type="date"] {
    background: #2e2e2e;
    border: 1px solid #3a3a3a;
    border-radius: 6px;
    color: #e0e0e0;
    font-size: 14px;
    padding: 10px 13px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .field input:focus { border-color: #3b5bdb; }
  .field input::placeholder { color: #555; }
  .field input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(0.6);
    cursor: pointer;
  }

  .hint {
    font-size: 11px;
    color: #666;
    margin-top: 2px;
  }

  /* CHIPS */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 6px;
  }
  .chip {
    background: #2e2e2e;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    color: #aaa;
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
    padding: 3px 9px;
    transition: all 0.15s;
  }
  .chip:hover, .chip.active {
    background: #1c3faa;
    border-color: #3b5bdb;
    color: #fff;
  }

  /* DATE QUICK BUTTONS */
  .date-quick {
    display: flex;
    gap: 8px;
    margin-top: 8px;
    flex-wrap: wrap;
  }
  .date-btn {
    background: #2e2e2e;
    border: 1px solid #3a3a3a;
    border-radius: 5px;
    color: #aaa;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 12px;
    transition: all 0.15s;
  }
  .date-btn:hover {
    background: #1c3faa;
    border-color: #3b5bdb;
    color: #fff;
  }

  /* RESULT BOX */
  .result-box {
    background: #1e2a4a;
    border: 1.5px solid #3b5bdb;
    border-radius: 8px;
    margin-top: 22px;
    padding: 20px 22px 16px;
    min-height: 80px;
  }
  .result-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #7c9fff;
    margin-bottom: 10px;
    text-transform: uppercase;
  }
  .result-value {
    font-size: 22px;
    font-weight: 800;
    color: #c5d5ff;
    letter-spacing: 0.3px;
    word-break: break-all;
  }
  .result-value.placeholder { color: #4a5580; font-size: 18px; font-weight: 500; }

  /* VALIDATION */
  .validation-error {
    font-size: 12px;
    color: #f03e3e;
    margin-top: 8px;
    display: none;
  }
  .validation-error.show { display: block; }

  /* ACTION BUTTONS */
  .actions {
    display: flex;
    gap: 10px;
    margin-top: 18px;
  }
  .btn {
    border: none;
    border-radius: 7px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 700;
    padding: 10px 20px;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .btn-copy {
    background: #3b5bdb;
    color: #fff;
  }
  .btn-copy:hover { background: #2f4ac7; }
  .btn-copy.copied { background: #2f9e44; }
  .btn-reset {
    background: #2e2e2e;
    border: 1px solid #3a3a3a;
    color: #aaa;
  }
  .btn-reset:hover { background: #383838; color: #fff; }

  /* CHECKER SECTION */
  .checker-input {
    background: #2e2e2e;
    border: 1px solid #3a3a3a;
    border-radius: 6px;
    color: #e0e0e0;
    font-size: 14px;
    padding: 10px 13px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    margin-top: 8px;
  }
  .checker-input:focus { border-color: #3b5bdb; }
  .checker-input::placeholder { color: #555; }

  .checker-result {
    margin-top: 12px;
    font-size: 13px;
    display: none;
  }
  .checker-result.show { display: block; }
  .checker-result.valid { color: #51cf66; }
  .checker-result.invalid { color: #f03e3e; }
  .checker-result ul {
    margin-top: 6px;
    padding-left: 18px;
  }
  .checker-result li { margin-bottom: 3px; }

  /* NAMING RULE SUMMARY */
  .rule-code {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 6px;
    color: #7c9fff;
    font-family: 'Courier New', monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    padding: 14px 18px;
    margin-bottom: 16px;
    text-align: center;
  }

  .rule-list { list-style: none; }
  .rule-list li {
    font-size: 13px;
    color: #999;
    padding: 4px 0;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .rule-list li .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
  }
  .dot-blue   { background: #3b5bdb; }
  .dot-green  { background: #2f9e44; }
  .dot-yellow { background: #f08c00; }
  .dot-red    { background: #e03131; }

  .rule-list strong { color: #e0e0e0; }

  .wiki-link {
    display: inline-block;
    margin-top: 14px;
    font-size: 13px;
    color: #5c7cfa;
    text-decoration: none;
  }
  .wiki-link:hover { text-decoration: underline; }

  /* FOOTER */
  .footer {
    text-align: center;
    margin-top: 40px;
    font-size: 12px;
    color: #555;
  }
  .footer a { color: #5c7cfa; text-decoration: none; }
  .footer a:hover { text-decoration: underline; }
</style>
</head>
<body>

<div class="top-badge">
  <span>KRAFTON · AI TRANSFORMATION TEAM</span>
</div>

<div class="header">
  <h1>🔑 AI API Key Name Generator</h1>
  <p>Naming Rule에 맞는 API Key 이름을 자동으로 생성하고 검토해드립니다</p>
</div>

<!-- GENERATOR CARD -->
<div class="card">
  <div class="card-title"><span class="icon">⚙️</span> KEY NAME 생성기</div>

  <div class="grid-2">
    <!-- Email Username -->
    <div class="field">
      <label>이메일 USERNAME <span class="req">*</span></label>
      <input type="text" id="username" placeholder="e.g. jaejun.lee" oninput="generate()">
      <div class="hint">@xxx.com 앞의 username만 입력 (예: jaejun.lee)</div>
    </div>

    <!-- Environment Code -->
    <div class="field">
      <label>환경코드 (ENVIRONMENT) <span class="req">*</span></label>
      <input type="text" id="env" placeholder="e.g. SLACK" oninput="generate()">
      <div class="chips">
        <span class="chip" onclick="setChip('env', 'SLACK', this)">SLACK</span>
        <span class="chip" onclick="setChip('env', 'KRIS', this)">KRIS</span>
        <span class="chip" onclick="setChip('env', 'DEV', this)">DEV</span>
        <span class="chip" onclick="setChip('env', 'PROD', this)">PROD</span>
        <span class="chip" onclick="setChip('env', 'TEST', this)">TEST</span>
        <span class="chip" onclick="setChip('env', 'CONF', this)">CONF</span>
        <span class="chip" onclick="setChip('env', 'JIRA', this)">JIRA</span>
        <span class="chip" onclick="setChip('env', 'WEB', this)">WEB</span>
        <span class="chip" onclick="setChip('env', 'BATCH', this)">BATCH</span>
        <span class="chip" onclick="setChip('env', 'API', this)">API</span>
      </div>
    </div>

    <!-- Purpose -->
    <div class="field">
      <label>목적 (PURPOSE) <span class="req">*</span></label>
      <input type="text" id="purpose" placeholder="e.g. chatbot" oninput="generate()">
      <div class="hint">10자 이내 권장, 영문·숫자·하이픈만 사용</div>
      <div class="chips">
        <span class="chip" onclick="setChip('purpose', 'chatbot', this)">chatbot</span>
        <span class="chip" onclick="setChip('purpose', 'agent', this)">agent</span>
        <span class="chip" onclick="setChip('purpose', 'askAI', this)">askAI</span>
        <span class="chip" onclick="setChip('purpose', 'integration', this)">integration</span>
        <span class="chip" onclick="setChip('purpose', 'automation', this)">automation</span>
        <span class="chip" onclick="setChip('purpose', 'testing', this)">testing</span>
        <span class="chip" onclick="setChip('purpose', 'poc', this)">poc</span>
        <span class="chip" onclick="setChip('purpose', 'analytics', this)">analytics</span>
      </div>
    </div>

    <!-- Expiry Date -->
    <div class="field">
      <label>만료일 <span class="req">*</span></label>
      <input type="date" id="expiry" onchange="generate()">
      <div class="date-quick">
        <button class="date-btn" onclick="addMonths(1)">+1개월</button>
        <button class="date-btn" onclick="addMonths(3)">+3개월</button>
        <button class="date-btn" onclick="addMonths(6)">+6개월</button>
        <button class="date-btn" onclick="addMonths(12)">+12개월</button>
      </div>
    </div>
  </div>

  <!-- Result -->
  <div class="result-box">
    <div class="result-label">생성된 KEY NAME</div>
    <div class="result-value placeholder" id="result">필드를 입력하면 자동으로 생성됩니다</div>
  </div>
  <div class="validation-error" id="valError"></div>

  <div class="actions">
    <button class="btn btn-copy" id="copyBtn" onclick="copyResult()">📋 복사하기</button>
    <button class="btn btn-reset" onclick="resetAll()">🔄 초기화</button>
  </div>
</div>

<!-- CHECKER CARD -->
<div class="card">
  <div class="card-title"><span class="icon">🔍</span> 기존 KEY NAME 검토기</div>
  <div style="font-size: 13px; color: #888; margin-bottom: 4px;">이미 발급한 Key 이름이 Naming Rule에 맞는지 확인해보세요.</div>
  <input type="text" class="checker-input" id="checkerInput"
    placeholder="e.g. jaejun.lee-SLACK-chatbot-exp250215"
    oninput="checkKeyName()">
  <div class="checker-result" id="checkerResult"></div>
</div>

<!-- NAMING RULE CARD -->
<div class="card">
  <div class="card-title"><span class="icon">📌</span> NAMING RULE 요약</div>
  <div class="rule-code">{username}-{환경코드}-{목적}-{expYYYYMMDD}</div>
  <ul class="rule-list">
    <li>
      <span class="dot dot-blue"></span>
      <span><strong>username</strong> — 이메일 @xxx.com 앞 부분 (예: jaejun.lee)</span>
    </li>
    <li>
      <span class="dot dot-green"></span>
      <span><strong>환경코드</strong> — 배포 위치 약어 (SLACK, DEV, PROD, KRIS ...)</span>
    </li>
    <li>
      <span class="dot dot-yellow"></span>
      <span><strong>목적</strong> — 10자 이내, 영문·숫자·하이픈 (chatbot, agent ...)</span>
    </li>
    <li>
      <span class="dot dot-red"></span>
      <span><strong>만료일</strong> — expYYYYMMDD 또는 expYYMMDD 형식 (예: exp260305)</span>
    </li>
  </ul>
  <a class="wiki-link" href="https://krafton.atlassian.net/wiki/spaces/KRAFTONAI/pages/795140288/" target="_blank">📄 전체 Naming Rule Wiki 보기 →</a>
</div>

<div class="footer">
  Powered by KRIS · AI Transformation Team (AIT) · 문의: <a href="mailto:jiyunl@krafton.com">jiyunl@krafton.com</a>
</div>

<script>
  function generate() {
    const username = document.getElementById('username').value.trim();
    const env      = document.getElementById('env').value.trim().toUpperCase();
    const purpose  = document.getElementById('purpose').value.trim();
    const expiry   = document.getElementById('expiry').value; // YYYY-MM-DD

    const resultEl = document.getElementById('result');
    const errEl    = document.getElementById('valError');

    // Clear errors
    errEl.textContent = '';
    errEl.classList.remove('show');

    if (!username && !env && !purpose && !expiry) {
      resultEl.textContent = '필드를 입력하면 자동으로 생성됩니다';
      resultEl.className = 'result-value placeholder';
      return;
    }

    // Validation
    const errors = [];
    if (!username) errors.push('이메일 username을 입력해주세요');
    if (!env) errors.push('환경코드를 입력해주세요');
    if (!purpose) errors.push('목적을 입력해주세요');
    if (!expiry) errors.push('만료일을 선택해주세요');

    if (purpose && !/^[a-zA-Z0-9\-_]+$/.test(purpose)) {
      errors.push('목적은 영문·숫자·하이픈만 사용 가능합니다');
    }

    if (errors.length > 0) {
      errEl.textContent = errors.join(' / ');
      errEl.classList.add('show');
      resultEl.textContent = '필드를 모두 올바르게 입력해주세요';
      resultEl.className = 'result-value placeholder';
      return;
    }

    // Format date as YYYYMMDD
    const dateStr = expiry.replace(/-/g, ''); // YYYYMMDD
    const keyName = `${username}-${env}-${purpose}-exp${dateStr}`;

    resultEl.textContent = keyName;
    resultEl.className = 'result-value';
  }

  function setChip(fieldId, value, el) {
    // Toggle chips
    const chips = el.parentElement.querySelectorAll('.chip');
    chips.forEach(c => c.classList.remove('active'));
    
    const input = document.getElementById(fieldId);
    if (input.value === value) {
      input.value = '';
      generate();
      return;
    }
    el.classList.add('active');
    input.value = value;
    generate();
  }

  function addMonths(n) {
    const d = new Date();
    d.setMonth(d.getMonth() + n);
    const yyyy = d.getFullYear();
    const mm   = String(d.getMonth() + 1).padStart(2, '0');
    const dd   = String(d.getDate()).padStart(2, '0');
    document.getElementById('expiry').value = `${yyyy}-${mm}-${dd}`;
    generate();
  }

  function copyResult() {
    const val = document.getElementById('result').textContent;
    if (!val || val.includes('필드를')) return;

    navigator.clipboard.writeText(val).then(() => {
      const btn = document.getElementById('copyBtn');
      btn.textContent = '✅ 복사됨!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.innerHTML = '📋 복사하기';
        btn.classList.remove('copied');
      }, 2000);
    });
  }

  function resetAll() {
    ['username', 'env', 'purpose', 'expiry'].forEach(id => {
      document.getElementById(id).value = '';
    });
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    document.getElementById('result').textContent = '필드를 입력하면 자동으로 생성됩니다';
    document.getElementById('result').className = 'result-value placeholder';
    document.getElementById('valError').classList.remove('show');
  }

  // ---- CHECKER ----
  function checkKeyName() {
    const raw    = document.getElementById('checkerInput').value.trim();
    const resEl  = document.getElementById('checkerResult');

    if (!raw) {
      resEl.classList.remove('show');
      return;
    }

    const issues = [];
    const parts  = raw.split('-');

    // Must have at least 4 parts (username can have dots; last part is exp, third-to-last is purpose, etc.)
    // Format: {username}-{env}-{purpose}-{expXXXXXX}
    // Find expiry part
    const expIdx = parts.findIndex(p => /^exp\d{6,8}$/i.test(p));

    if (expIdx === -1) {
      issues.push('만료일 부분이 없거나 형식이 잘못됐습니다 (expYYYYMMDD 또는 expYYMMDD 형식 필요)');
    } else {
      const expPart = parts[expIdx];
      const digits = expPart.slice(3);
      if (digits.length === 6) {
        // expYYMMDD
        const yy = parseInt(digits.slice(0,2));
        const mm = parseInt(digits.slice(2,4));
        const dd = parseInt(digits.slice(4,6));
        if (mm < 1 || mm > 12 || dd < 1 || dd > 31) {
          issues.push('만료일 날짜 값이 올바르지 않습니다');
        }
      } else if (digits.length === 8) {
        // expYYYYMMDD
        const mm = parseInt(digits.slice(4,6));
        const dd = parseInt(digits.slice(6,8));
        if (mm < 1 || mm > 12 || dd < 1 || dd > 31) {
          issues.push('만료일 날짜 값이 올바르지 않습니다');
        }
      } else {
        issues.push('만료일 형식은 expYYYYMMDD 또는 expYYMMDD 여야 합니다');
      }
    }

    if (expIdx < 3) {
      issues.push('username, 환경코드, 목적 파트가 부족합니다');
    }

    if (expIdx >= 3) {
      const userPart    = parts.slice(0, expIdx - 2).join('-');
      const envPart     = parts[expIdx - 2];
      const purposePart = parts[expIdx - 1];

      if (!userPart) issues.push('username 파트가 비어있습니다');
      if (!envPart)  issues.push('환경코드 파트가 비어있습니다');
      if (!purposePart) issues.push('목적 파트가 비어있습니다');

      if (purposePart && purposePart.length > 15) {
        issues.push(`목적(${purposePart})이 너무 깁니다 — 10자 이내를 권장합니다`);
      }
      if (purposePart && !/^[a-zA-Z0-9\-_]+$/.test(purposePart)) {
        issues.push('목적 파트에 허용되지 않는 문자가 포함되어 있습니다');
      }
    }

    resEl.classList.add('show');
    if (issues.length === 0) {
      resEl.className = 'checker-result show valid';
      resEl.innerHTML = '✅ Naming Rule을 준수하고 있습니다!';
    } else {
      resEl.className = 'checker-result show invalid';
      resEl.innerHTML = '❌ 아래 항목을 확인해주세요:<ul>' +
        issues.map(i => `<li>${i}</li>`).join('') + '</ul>';
    }
  }
</script>
</body>
</html>
